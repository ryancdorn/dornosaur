<script is:inline>
  // ── Click a series header to collapse/expand its book grid ──
  document.querySelectorAll('[data-toggle-series]').forEach((header) => {
    const group = header.closest('.series-group');
    if (!group) return;
    header.addEventListener('click', () => {
      const collapsed = group.classList.toggle('is-collapsed');
      header.setAttribute('aria-expanded', String(!collapsed));
    });
  });

  // ── Back-to-top "Books." link in the genre nav ──
  document.querySelectorAll('[data-scroll-top]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // ── Global status filters (Read / Reading / Queued / Unpurchased pills in the sticky nav) ──
  (() => {
    const pills = document.querySelectorAll('.filter-bar .pill');
    if (pills.length === 0) return;
    const books = document.querySelectorAll('.book');
    const groups = document.querySelectorAll('.series-group');
    const sections = document.querySelectorAll('.gs');
    // Initialize active set from is-active class so JSX-declared defaults (Unpurchased OFF) stick.
    const active = new Set(
      Array.from(pills).filter((p) => p.classList.contains('is-active')).map((p) => p.dataset.status),
    );

    function render() {
      books.forEach((book) => {
        book.classList.toggle('is-hidden', !active.has(book.dataset.status));
      });
      groups.forEach((group) => {
        const visible = group.querySelectorAll('.book:not(.is-hidden)').length;
        group.classList.toggle('is-hidden', visible === 0);
      });
      sections.forEach((section) => {
        const visible = section.querySelectorAll('.book:not(.is-hidden)').length;
        section.classList.toggle('is-hidden', visible === 0);
      });
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const status = pill.dataset.status;
        if (active.has(status)) {
          active.delete(status);
          pill.classList.remove('is-active');
          pill.setAttribute('aria-pressed', 'false');
        } else {
          active.add(status);
          pill.classList.add('is-active');
          pill.setAttribute('aria-pressed', 'true');
        }
        render();
      });
    });

    render();
  })();

  // ── Highlight active genre in the nav while scrolling ──
  const navLinks = new Map();
  document.querySelectorAll('.genre-link').forEach((link) => {
    navLinks.set(link.dataset.target, link);
  });

  if ('IntersectionObserver' in window && navLinks.size > 0) {
    const observer = new IntersectionObserver((entries) => {
      // Pick the entry closest to the top of the viewport that is intersecting
      const visible = entries
        .filter(e => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible.length === 0) return;
      const id = visible[0].target.id;
      navLinks.forEach((link, key) => {
        link.classList.toggle('is-current', key === id);
      });
    }, {
      // Trigger when the top of a section crosses just below the sticky nav (~250px)
      rootMargin: '-250px 0px -50% 0px',
      threshold: 0,
    });
    document.querySelectorAll('.gs').forEach(s => observer.observe(s));
  }
</script>
