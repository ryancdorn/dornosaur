---
import Layout from '../layouts/Layout.astro';
import records from '../data/vinyl.json';

const genres = [
  { key: 'hiphop', label: 'Hip Hop',    desc: 'The culture, the craft, the classics' },
  { key: 'rock',   label: 'Rock',       desc: 'Guitar gods, prog epics, and everything loud' },
  { key: 'soul',   label: 'Pop & Soul', desc: 'Groove, feeling, and the floor at 2am' },
];
---

<Layout title="Vinyl" fullWidth={true} pageTint="vinyl">

  <div class="page-hero vinyl-hero">
    <div class="grooves" aria-hidden="true"></div>
    <div class="page-hero-inner">
      <p class="eyebrow">Record collection</p>
      <h1>Vinyl.</h1>
      <div class="stats-row">
        <div class="stat">
          <span class="stat-num">{records.length}</span>
          <span class="stat-label">Records</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num">{records.filter((r: any) => r.genre === 'hiphop').length}</span>
          <span class="stat-label">Hip Hop</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num">{records.filter((r: any) => r.genre === 'rock').length}</span>
          <span class="stat-label">Rock</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num">{records.filter((r: any) => r.genre === 'soul').length}</span>
          <span class="stat-label">Pop & Soul</span>
        </div>
      </div>
    </div>
  </div>

  <nav class="genre-nav" aria-label="Jump to genre">
    <div class="genre-nav-inner">
      {genres.filter(g => records.some((r: any) => r.genre === g.key)).map(g => {
        const count = records.filter((r: any) => r.genre === g.key).length;
        return (
          <a href={`#${g.key}`} class:list={['genre-link', g.key]} data-target={g.key}>
            <span class="genre-link-name">{g.label}</span>
            <span class="genre-link-count">{count}</span>
          </a>
        );
      })}
    </div>
  </nav>

  {genres.map(genre => {
    const genreRecords = records.filter((r: any) => r.genre === genre.key);
    if (genreRecords.length === 0) return null;
    return (
      <section id={genre.key} class:list={['gs', genre.key]}>
        <div class="gs-banner">
          <div class="gs-banner-inner">
            <p class="gs-eyebrow">{genre.key.toUpperCase()} · {genreRecords.length} RECORDS</p>
            <h2 class="gs-title">{genre.label}</h2>
            <p class="gs-desc">{genre.desc}</p>
          </div>
        </div>
        <div class="gs-shelf">
          <div class="gs-shelf-inner">
            <div class="record-grid">
              {genreRecords.map((record: any) => (
                <div class="record-card">
                  <div class="cover-wrap">
                    <img src={record.cover} alt={`${record.title} by ${record.artist}`} loading="lazy" referrerpolicy="no-referrer" />
                    <div class="cover-overlay">
                      <span class="overlay-format">{record.format}</span>
                    </div>
                  </div>
                  <div class="record-info">
                    <p class="rtitle">{record.title}</p>
                    <p class="rartist">{record.artist}</p>
                    <p class="rmeta">{record.year}{record.pressing ? ` · ${record.pressing}` : ''}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    );
  })}

</Layout>

<style>
  .vinyl-hero { padding: 6rem 0 4.5rem; }

  /* Subtle vinyl-groove rings — pure CSS, decorative, low opacity */
  .grooves {
    position: absolute;
    top: 50%;
    right: -180px;
    transform: translateY(-50%);
    width: 720px;
    height: 720px;
    border-radius: 50%;
    background:
      repeating-radial-gradient(
        circle at center,
        transparent 0,
        transparent 6px,
        currentColor 6px,
        currentColor 7px
      );
    color: var(--text);
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }
  [data-theme="light"] .grooves { opacity: 0.06; }

  /* ── Sticky genre nav ─────────────────────────────────────── */
  .genre-nav {
    position: sticky;
    top: 62px;
    z-index: 50;
    background: rgba(10, 10, 14, 0.92);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-top: 1px solid #1A1A20;
    border-bottom: 1px solid #1A1A20;
  }
  .genre-nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.4rem;
    justify-content: center;
  }
  .genre-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.95rem 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(237, 234, 229, 0.55);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .genre-link:hover { text-decoration: none; color: #EDEAE5; background: rgba(255,255,255,0.03); }
  .genre-link-count {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    letter-spacing: 0;
    color: rgba(237, 234, 229, 0.4);
  }
  .genre-link.is-current {
    color: var(--genre-accent, #EDEAE5);
    border-bottom-color: var(--genre-accent, #EDEAE5);
  }
  .genre-link.is-current .genre-link-count { color: var(--genre-accent, #EDEAE5); opacity: 0.85; }

  .genre-link.hiphop { --genre-accent: #D4A820; }
  .genre-link.rock   { --genre-accent: #C84838; }
  .genre-link.soul   { --genre-accent: #A878DC; }

  /* ── Genre sections (always dark/immersive) ──────────────── */
  .gs {
    border-top: 1px solid #1A1A20;
    background: #0E0E12;
    color: #EDEAE5;
    scroll-margin-top: 110px;
  }
  .gs-banner { padding: 4rem 0 3rem; }
  .gs-banner-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }
  .gs-eyebrow {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
    opacity: 0.55;
  }
  .gs-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.75rem, 5.5vw, 4.75rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
  }
  .gs-desc {
    font-family: 'Lora', serif;
    font-size: 1rem;
    font-style: italic;
    opacity: 0.55;
  }

  .gs-shelf-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem 2.5rem 4rem;
  }

  .record-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.75rem;
  }
  .record-card { display: flex; flex-direction: column; gap: 0.65rem; }
  .cover-wrap {
    position: relative;
    border-radius: 2px;
    overflow: hidden;
    aspect-ratio: 1;
    box-shadow: 0 8px 24px rgba(0,0,0,0.55), 0 2px 6px rgba(0,0,0,0.4);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .record-card:hover .cover-wrap { transform: translateY(-6px) scale(1.02); }
  .cover-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .cover-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 8px;
    background: rgba(0,0,0,0);
    transition: background 0.2s;
  }
  .record-card:hover .cover-overlay { background: rgba(0,0,0,0.35); }
  .overlay-format {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: rgba(0,0,0,0.8);
    color: rgba(255,255,255,0.85);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s, transform 0.2s;
  }
  .record-card:hover .overlay-format { opacity: 1; transform: translateY(0); }

  .rtitle  { font-size: 0.82rem; font-weight: 700; line-height: 1.3; margin: 0 0 0.2rem; }
  .rartist { font-size: 0.72rem; opacity: 0.55; margin: 0 0 0.2rem; }
  .rmeta   { font-size: 0.62rem; opacity: 0.35; margin: 0; line-height: 1.5; }

  /* ── Genre themes ────────────────────────────────────────── */
  .hiphop .gs-banner {
    background: linear-gradient(135deg, #0B0904 0%, #14100A 100%);
    border-bottom: 1px solid rgba(212,168,32,0.25);
  }
  .hiphop .gs-eyebrow { color: rgba(212,168,32,0.65); }
  .hiphop .gs-title   { color: #D4A820; text-shadow: 0 0 60px rgba(212,168,32,0.18); }
  .hiphop .gs-desc    { color: rgba(212,168,32,0.55); }
  .hiphop .gs-shelf   { background: #0A0805; }
  .hiphop .rtitle     { color: #D4BC78; }
  .hiphop .rartist    { color: #8A7440; }
  .hiphop .cover-wrap { box-shadow: 0 8px 24px rgba(180,130,10,0.14), 0 2px 6px rgba(0,0,0,0.5); }
  .hiphop .record-card:hover .cover-wrap { box-shadow: 0 20px 40px rgba(180,130,10,0.28); }

  .rock .gs-banner {
    background: linear-gradient(135deg, #0B0606 0%, #150808 100%);
    border-bottom: 1px solid rgba(200,72,56,0.25);
  }
  .rock .gs-eyebrow { color: rgba(200,72,56,0.65); }
  .rock .gs-title   { color: #C84838; text-shadow: 0 0 60px rgba(200,72,56,0.2); }
  .rock .gs-desc    { color: rgba(200,72,56,0.55); }
  .rock .gs-shelf   { background: #0A0606; }
  .rock .rtitle     { color: #D4B0B0; }
  .rock .rartist    { color: #804444; }
  .rock .cover-wrap { box-shadow: 0 8px 24px rgba(160,40,30,0.14), 0 2px 6px rgba(0,0,0,0.5); }
  .rock .record-card:hover .cover-wrap { box-shadow: 0 20px 40px rgba(160,40,30,0.3); }

  .soul .gs-banner {
    background: linear-gradient(135deg, #08060B 0%, #100A18 100%);
    border-bottom: 1px solid rgba(168,120,220,0.25);
  }
  .soul .gs-eyebrow { color: rgba(168,120,220,0.65); }
  .soul .gs-title   { color: #A878DC; text-shadow: 0 0 60px rgba(168,120,220,0.22); }
  .soul .gs-desc    { color: rgba(168,120,220,0.55); }
  .soul .gs-shelf   { background: #07050A; }
  .soul .rtitle     { color: #C8B0E4; }
  .soul .rartist    { color: #6E4E94; }
  .soul .cover-wrap { box-shadow: 0 8px 24px rgba(120,70,180,0.14), 0 2px 6px rgba(0,0,0,0.5); }
  .soul .record-card:hover .cover-wrap { box-shadow: 0 20px 40px rgba(120,70,180,0.3); }
</style>

<script is:inline>
  // ── Highlight active genre in the nav while scrolling ──
  const navLinks = new Map();
  document.querySelectorAll('.genre-link').forEach((link) => {
    navLinks.set(link.dataset.target, link);
  });

  if ('IntersectionObserver' in window && navLinks.size > 0) {
    const observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter(e => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible.length === 0) return;
      const id = visible[0].target.id;
      navLinks.forEach((link, key) => {
        link.classList.toggle('is-current', key === id);
      });
    }, {
      rootMargin: '-110px 0px -60% 0px',
      threshold: 0,
    });
    document.querySelectorAll('.gs').forEach(s => observer.observe(s));
  }
</script>
