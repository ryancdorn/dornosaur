---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vinyl" fullWidth={true}>

  <div class="vinyl-page">

    <div class="wood-header">
      <div class="header-inner">
        <p class="eyebrow">Record Collection</p>
        <h1>Vinyl</h1>
        <p class="sub">The physical kind — warping on a real turntable.</p>
      </div>
    </div>

    <div class="shelf-area">
      <div class="shelf-inner">
        <p class="coming-soon">Collection loading soon — stay tuned.</p>
      </div>
      <div class="shelf-ledge"></div>
    </div>

    <div class="wood-footer"></div>

  </div>

</Layout>

<style>
  .vinyl-page { display: flex; flex-direction: column; min-height: calc(100vh - 62px); }

  /* ── Wood grain ──────────────────────────────────────────── */
  .wood-header, .wood-footer {
    background-color: #2E1608;
    background-image:
      repeating-linear-gradient(
        89deg,
        transparent 0px, transparent 2px,
        rgba(90,40,5,0.3) 2px, rgba(90,40,5,0.3) 3px
      ),
      repeating-linear-gradient(
        91deg,
        transparent 0px, transparent 12px,
        rgba(10,5,0,0.15) 12px, rgba(10,5,0,0.15) 13px
      ),
      repeating-linear-gradient(
        88.5deg,
        transparent 0px, transparent 50px,
        rgba(110,55,12,0.07) 50px, rgba(110,55,12,0.07) 80px
      ),
      linear-gradient(
        180deg,
        #3D2208 0%,  #2E1608 15%,
        #4A2A10 30%, #2E1608 45%,
        #553018 58%, #2E1608 72%,
        #3F2010 85%, #2E1608 100%
      );
  }

  /* ── Header panel ────────────────────────────────────────── */
  .wood-header {
    border-bottom: 4px solid #7A5018;
    box-shadow: 0 4px 30px rgba(0,0,0,0.7);
    padding: 4rem 0 3.5rem;
    position: relative;
  }
  .wood-header::after {
    content: '';
    position: absolute;
    bottom: -8px; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, #5A3810, #9A6828, #5A3810, #9A6828, #5A3810);
    opacity: 0.55;
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #C4924A;
    margin-bottom: 1rem;
    font-family: 'Inter', sans-serif;
  }

  .wood-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3.5rem, 7vw, 6rem);
    font-weight: 700;
    font-style: italic;
    color: #F5D98E;
    text-shadow: 0 2px 20px rgba(0,0,0,0.7), 0 0 60px rgba(180,120,30,0.15);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .sub {
    color: #A07840;
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 1rem;
  }

  /* ── Shelf area ──────────────────────────────────────────── */
  .shelf-area {
    flex: 1;
    background: #0E0804;
    position: relative;
  }

  .shelf-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 2.5rem;
    min-height: 300px;
  }

  .coming-soon {
    color: #3A2808;
    font-style: italic;
    font-family: 'Lora', serif;
    font-size: 1rem;
  }

  /* Shelf ledge */
  .shelf-ledge {
    background: linear-gradient(180deg, #4A2810, #2E1808);
    height: 22px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.7);
    border-top: 2px solid #7A5018;
  }

  /* ── Footer wood panel ───────────────────────────────────── */
  .wood-footer {
    height: 60px;
    border-top: 4px solid #5A3810;
  }
</style>
